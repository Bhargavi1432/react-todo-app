CREATE DATABASE todo_app;

USE todo_app;

-- Users Table
CREATE TABLE users (
  id INT AUTO_INCREMENT PRIMARY KEY,
  username VARCHAR(50) UNIQUE,
  password VARCHAR(255)
);

-- Tasks Table
CREATE TABLE tasks (
  id INT AUTO_INCREMENT PRIMARY KEY,
  user_id INT,
  title VARCHAR(255),
  category VARCHAR(50),
  due_date DATE,
  priority ENUM('low','medium','high'),
  FOREIGN KEY (user_id) REFERENCES users(id)
);