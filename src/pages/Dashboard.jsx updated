import { useState, useEffect } from "react";
import API from "../services/api";

export default function Dashboard() {
  const [tasks, setTasks] = useState([]);
  const [newTask, setNewTask] = useState({
    title: "",
    category: "",
    priority: "",
    due_date: ""
  });

  const user = JSON.parse(localStorage.getItem("user"));

  // 🔹 Fetch tasks
  const fetchTasks = async () => {
    try {
      const res = await API.get(`/tasks/${user.id}`);
      setTasks(res.data);
    } catch (error) {
      console.error(error);
      alert("Error fetching tasks");
    }
  };

  useEffect(() => {
    fetchTasks();
  }, []);

  // 🔹 Add task
  const handleAddTask = async () => {
    if (!newTask.title) {
      alert("Task title is required");
      return;
    }

    try {
      await API.post("/tasks", { user_id: user.id, ...newTask });
      setNewTask({ title: "", category: "", priority: "", due_date: "" });
      fetchTasks();
    } catch (error) {
      console.error(error);
      alert("Error adding task");
    }
  };

  // 🔹 Update task (FIXED)
  const handleUpdateTask = async (task) => {
    const title = prompt("Enter new title", task.title);
    const priority = prompt("Enter priority", task.priority);
    const due_date = prompt("Enter due date (YYYY-MM-DD)", task.due_date);

    if (!title) return;

    try {
      await API.put(`/tasks/${task.id}`, {
        title,
        priority,
        due_date
      });
      fetchTasks();
    } catch (error) {
      console.error(error);
      alert("Error updating task");
    }
  };

  // 🔹 Delete task
  const handleDeleteTask = async (taskId) => {
    if (!window.confirm("Are you sure?")) return;

    try {
      await API.delete(`/tasks/${taskId}`);
      fetchTasks();
    } catch (error) {
      console.error(error);
      alert("Error deleting task");
    }
  };

  return (
    <div style={{ padding: "20px" }}>
      <h2>Welcome, {user.username}</h2>

      {/* ➕ Add Task */}
      <h3>Add New Task</h3>
      <input
        placeholder="Title"
        value={newTask.title}
        onChange={(e) => setNewTask({ ...newTask, title: e.target.value })}
      />
      <input
        placeholder="Category"
        value={newTask.category}
        onChange={(e) => setNewTask({ ...newTask, category: e.target.value })}
      />
      <input
        placeholder="Priority"
        value={newTask.priority}
        onChange={(e) => setNewTask({ ...newTask, priority: e.target.value })}
      />
      <input
        type="date"
        value={newTask.due_date}
        onChange={(e) => setNewTask({ ...newTask, due_date: e.target.value })}
      />
      <button onClick={handleAddTask}>Add Task</button>

      {/* 📋 Task List */}
      <h3>Your Tasks</h3>
      <ul>
        {tasks.map((task) => (
          <li key={task.id} style={{ marginBottom: "10px" }}>
            <strong>{task.title}</strong> | {task.category} | {task.priority} | {task.due_date}

            <button
              onClick={() => handleUpdateTask(task)}
              style={{ marginLeft: "10px" }}
            >
              Edit
            </button>

            <button
              onClick={() => handleDeleteTask(task.id)}
              style={{ marginLeft: "5px" }}
            >
              Delete
            </button>
          </li>
        ))}
      </ul>
    </div>
  );
}